# ============================================================
# HashInsight Enterprise - Environment Configuration
# ============================================================
# CRITICAL: Copy to .env and set all REQUIRED variables
# Application will FAIL TO START if required variables are missing
# ============================================================

# ==================== REQUIRED (启动必须) ====================

# Database connection string (PostgreSQL) - REQUIRED
DATABASE_URL=postgresql://hashinsight:hashinsight@localhost:5432/hashinsight
POSTGRES_USER=hashinsight
POSTGRES_PASSWORD=hashinsight

# Session secret key - REQUIRED (CRITICAL SECURITY)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-this-in-production-use-random-string

# ==================== RECOMMENDED ====================

# Redis for caching and task queue
REDIS_URL=redis://localhost:6379/0

# Flask environment (development/production)
FLASK_ENV=development

# CRM Integration API Key (for API Key Auth)
API_KEY_1="hsi_crm_service_2025"
API_KEY_1_ROLE="owner"

# Optional: Intelligence Layer
OPENAI_API_KEY=sk-...

# Optional: External APIs
COINGECKO_API_KEY=
DERIBIT_API_KEY=
DERIBIT_API_SECRET=
COINWARZ_API_KEY=
BLOCKCHAIN_INFO_API_KEY=
MEMPOOL_SPACE_API_KEY=

# Feature Flags
FEATURE_WEB3_ENABLED=false
FEATURE_CRM_ENABLED=false
FEATURE_TREASURY_EXECUTION_ENABLED=false

# SLO监控配置
# P95 TTR（Time To Recalculate）阈值配置
ALERT_P95_TTR_WARNING=5000      # 警告阈值（毫秒），默认5秒
ALERT_P95_TTR_CRITICAL=10000    # 严重阈值（毫秒），默认10秒

# 成功率阈值配置
ALERT_SUCCESS_RATE_WARNING=99.9  # 警告阈值（%），默认99.9%
ALERT_SUCCESS_RATE_CRITICAL=99.0 # 严重阈值（%），默认99.0%

# 缓存命中率阈值配置
ALERT_CACHE_HIT_RATE_WARNING=80  # 警告阈值（%），默认80%
ALERT_CACHE_HIT_RATE_CRITICAL=50 # 严重阈值（%），默认50%

# TypeScript Microservices Layer
TS_API_PORT=3000                 # TypeScript API服务器端口
TS_API_KEY=hashinsight_dev_key_2025  # TypeScript API认证密钥
DEMO_MODE=1                      # 演示模式（1=启用，0=禁用）

# DataHub配置
DATAHUB_PRICE_TTL=30             # 价格缓存TTL（秒）
DATAHUB_CHAIN_TTL=300            # 链上数据缓存TTL（秒）
DATAHUB_TIMEOUT_MS=8000          # API请求超时（毫秒）

# 矿机适配器配置
ANTMINER_DEFAULT_PORT=4028
ANTMINER_TIMEOUT_MS=5000
WHATSMINER_DEFAULT_PORT=4028
WHATSMINER_TIMEOUT_MS=5000

# 限电策略配置
CURTAILMENT_MAX_THROTTLE=0.5     # 最大限功率比例（0-1）
CURTAILMENT_PRICE_THRESHOLD=0.10 # 触发限电的电价阈值（USD/kWh）
CURTAILMENT_REQUIRE_CONFIRM=true # 执行前需要确认
# 比特币网络常量（理想情况下应由 DataHub 实时提供；此处仅作回退默认值）
DEFAULT_NETWORK_HASHRATE_EH=600  # 全网算力默认值（EH/s）
BTC_BLOCK_REWARD=3.125           # 区块奖励（2024-04 减半后为 3.125 BTC）

# ==================== SECURITY / 安全（新增） ====================

# --- 边缘设备 token 静态加密 ---
# 设备 bearer token 既用于鉴权也用作控制面命令 HMAC 签名密钥，因此以
# “sha256 哈希（查找）+ 加密密文（HMAC）”形式落库，绝不存明文。
# 未设置时回退到从 SESSION_SECRET 派生（轮换该密钥会使已存 token 失效，
# 设备需重新注册）——生产强烈建议设置一个稳定、独立的密钥。
DEVICE_TOKEN_ENC_KEY=

# --- KYC / 制裁名单筛查（默认 fail-closed） ---
# 未配置真实提供商时，所有身份/地址/生物识别/制裁检查返回 NOT_VERIFIED（score=0），
# KYC 一律判为 REJECTED，绝不返回伪造的“已验证”。接入真实提供商前请保持为空。
# 注意：KYC_VERIFICATION_ENABLED=false 不再自动通过，而是 PENDING_REVIEW（需人工）。
KYC_PROVIDER=                    # 例如 onfido / jumio（暂未内置实现）
SANCTIONS_PROVIDER=              # 例如 chainalysis / ofac_api（暂未内置实现）
KYC_VERIFICATION_ENABLED=true

# --- 区块链私钥来源 ---
# env: 从 BLOCKCHAIN_PRIVATE_KEY 读取（默认，保持原行为；私钥永不写日志）
# kms/hsm: 占位实现，调用即抛 NotImplementedError（待接入真实 HSM/KMS）
BLOCKCHAIN_KEY_PROVIDER=env
BLOCKCHAIN_PRIVATE_KEY=          # 仅 BLOCKCHAIN_KEY_PROVIDER=env 时使用；生产应走 HSM/KMS

# --- 加密货币支付汇率 ---
# 默认使用实时价格；拿不到实时价格则 fail-closed（中止支付，避免错误定价）。
# 仅开发/测试可设为 true 以回退到静态硬编码汇率（生产切勿启用）。
ALLOW_STATIC_CRYPTO_RATES=false
# USDC 合约地址（可覆盖；默认为规范地址，会做 0x[40hex] 格式校验）
USDC_BASE_MAINNET_ADDRESS=
USDC_BASE_SEPOLIA_ADDRESS=

# --- 信封加密兜底主密钥 ---
# 生产模式（FLASK_ENV=production 或 ENABLE_PRODUCTION_CHECKS=1）下未设置将拒绝启动；
# 开发模式生成临时密钥，且只打印指纹、绝不打印密钥本身。
FALLBACK_MASTER_KEY=

# --- 审计日志防篡改 ---
# 启用每条审计记录的 sha256 哈希链 + 可选 HMAC 签名；链头持久化到侧车文件。
AUDIT_SIGNING_KEY=               # 设置后对每条审计记录做 HMAC-SHA256 签名
AUDIT_CHAIN_HEAD_FILE=           # 链头侧车文件路径（默认与审计日志同目录 .audit_chain_head）

# --- mTLS（默认关闭，接口就绪） ---
# 设为 true 时 require_mtls() 强制双向 TLS（无有效客户端证书一律 401，fail-closed）。
ENFORCE_MTLS=false

# --- AI 诊断阈值（可选；未设置时使用与历史一致的默认值） ---
AI_HASHRATE_DROP=0.2             # 算力下降比例阈值
AI_TEMP_HIGH_THRESHOLD=75        # 高温阈值（°C）
AI_TEMP_CRITICAL_THRESHOLD=85    # 临界高温阈值（°C）
AI_REJECT_RATE_HIGH=0.02         # 高拒绝率阈值
AI_POOL_LATENCY_HIGH=200         # 矿池高延迟阈值（ms）
AI_FAN_SPEED_LOW=2000            # 风扇低转速阈值（RPM）
AI_OFFLINE_MINUTES=5             # 离线判定时长（分钟）

# 注意：修改这些值需要重启应用才能生效
