# HashInsight 托管平台环境变量配置
# Sprint 1 - No Money DoD 版本

# --- 核心配置 ---
FLASK_ENV=production
PORT=5000
LOG_LEVEL=INFO
SECRET_KEY=change-me-please
SESSION_SECRET=change-me-please
ENVIRONMENT=production
DEBUG=false

# --- 数据库配置 ---
# 生产环境使用 PostgreSQL
DATABASE_URL=postgresql://username:password@localhost:5432/hashinsight_hosting

# --- 安全配置 (Sprint 1 要求) ---
CSRF_ENABLED=true
RATE_LIMITING_ENABLED=true
MAX_REQUESTS_PER_MINUTE=60
SECURE_HEADERS_ENABLED=true

# --- 启动优化 ---
ENABLE_BACKGROUND_SERVICES=0
FAST_STARTUP=1
SKIP_DATABASE_HEALTH_CHECK=1
MAX_DATA_LATENCY_SECONDS=60

# --- 权限控制 ---
AUTHORIZED_EMAILS=admin@example.com,host@example.com,client@example.com

# --- API Keys ---
COINWARZ_API_KEY=your_coinwarz_key_here
COINGECKO_API_KEY=your_coingecko_key_here
BLOCKCHAIN_INFO_API_KEY=your_blockchain_key_here

# --- 邮件服务 ---
GMAIL_EMAIL=your-email@gmail.com
GMAIL_PASSWORD=your-app-password

# --- 托管平台特定配置 ---
HOSTING_TRANSPARENCY_ENABLED=true
PUBLIC_STATUS_PAGES_ENABLED=true
BILLING_DISABLED=true

# --- No Money Mode (重要声明) ---
NO_MONEY_MODE=true
FINANCIAL_FEATURES_DISABLED=true

# --- 外部服务 ---
VERIFICATION_DOMAIN=calc.hashinsight.net
ANKR_RPC_URL=https://rpc.ankr.com/btc

# --- Replit hosting ---
REPLIT_DOMAINS=