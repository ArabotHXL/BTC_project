# =================================================================
# HashInsight 托管平台环境配置 (No-Money 版本)
# =================================================================

# --- 核心配置 ---
FLASK_ENV=development
PORT=5000
LOG_LEVEL=INFO
SESSION_SECRET=change-me-please

# --- 数据库配置 ---
# 生产环境使用 PostgreSQL，开发环境可使用 SQLite
# PostgreSQL 示例:
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/hashinsight_hosting
# 开发环境 SQLite:
# DATABASE_URL=sqlite:///hosting_platform.db

# --- 启动优化 ---
ENABLE_BACKGROUND_SERVICES=1
FAST_STARTUP=1
SKIP_DATABASE_HEALTH_CHECK=1

# --- 认证和授权 ---
# 允许登录的邮箱列表 (留空允许所有人 - 不推荐)
AUTHORIZED_EMAILS=admin@hashinsight.net,support@hashinsight.net

# --- No-Money 模式声明 ---
NO_MONEY_MODE=1
PLATFORM_DISCLAIMER=本系统不提供任何支付/托管/收益分发功能

# --- 托管平台配置 ---
# 组织隔离和RBAC
DEFAULT_ORG_ID=1
MULTI_ORG_ENABLED=1
RBAC_ENABLED=1
AUDIT_LOGS_ENABLED=1

# --- 安全配置 ---
CSRF_PROTECTION_ENABLED=1
RATE_LIMIT_ENABLED=1
RATE_LIMIT_REQUESTS_PER_HOUR=3600
RATE_LIMIT_REQUESTS_PER_MINUTE=60
SECURITY_HEADERS_ENABLED=1

# --- API 密钥 ---
COINWARZ_API_KEY=your_coinwarz_key_here
BLOCKCHAIN_INFO_API_KEY=
MEMPOOL_SPACE_API_KEY=
IP_API_KEY=

# --- 通知配置 (可选) ---
SMTP_ENABLED=0
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=1

# --- 公开状态页配置 ---
PUBLIC_STATUS_ENABLED=1
STATUS_PAGE_TITLE=HashInsight 托管状态
STATUS_PAGE_CONTACT=support@hashinsight.net

# --- 文件上传配置 ---
UPLOAD_FOLDER=uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=csv,xlsx,json

# --- 透明度和验证 ---
TRANSPARENCY_REPORTS_ENABLED=1
VERIFICATION_HASH_ENABLED=1
DISPUTE_RESOLUTION_ENABLED=1
DATA_RETENTION_DAYS=365

# --- 监控和日志 ---
PERFORMANCE_MONITORING=1
ERROR_TRACKING=1
LOG_FILE_PATH=logs/hosting_platform.log

# --- 部署配置 ---
REPLIT_DOMAINS=
DEPLOYMENT_ENVIRONMENT=development